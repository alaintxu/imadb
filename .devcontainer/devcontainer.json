{
    "name": "Node.js",
    "image": "registry.gitlab.com/mu-bd-ce/devcontainers/nodejs:latest",
    "customizations": {
        "vscode": {
            "extensions": [
                "Lokalise.i18n-ally",
                "dsznajder.es7-react-js-snippets"
            ]
        }
    },
	"runArgs": ["--sysctl", "net.ipv6.conf.all.disable_ipv6=1"],
    "postCreateCommand": "npm install -g npm@latest && npm install"
}